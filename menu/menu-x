# ==================================================
# 1. GRADASI HEADER FAST (EMAS -> BIRU -> UNGU)
# ==================================================
print_gradient() {
    local text="$1"
    awk -v text="$text" 'BEGIN {
        len = length(text);
        if (len <= 1) { print text; exit; }
        # Emas -> Biru -> Ungu
        rs=255; gs=215; bs=0;
        rm=0;   gm=128; bm=255;
        re=138; ge=43;  be=226;

        for (i=0; i<len; i++) {
            ratio = i / (len-1);
            if (ratio <= 0.5) {
                f = ratio * 2;
                r = int(rs + (rm - rs) * f);
                g = int(gs + (gm - gs) * f);
                b = int(bs + (bm - bs) * f);
            } else {
                f = (ratio - 0.5) * 2;
                r = int(rm + (re - rm) * f);
                g = int(gm + (ge - gm) * f);
                b = int(bm + (be - bm) * f);
            }
            printf "\033[38;2;%d;%d;%dm%s", r, g, b, substr(text, i+1, 1);
        }
        printf "\033[0m\n";
    }'
}

# ==================================================
